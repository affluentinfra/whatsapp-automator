# Flask Settings
FLASK_APP=app.py
FLASK_ENV=development
PORT=5000
SECRET_KEY=cap_secret_key_change_me_in_production

# Database & Storage Selection
# If SUPABASE_URL and SUPABASE_KEY are provided, the app uses Supabase (Postgres & Storage Bucket).
# Otherwise, it falls back to SQLite and local static files storage.
SUPABASE_URL=
SUPABASE_KEY=

# Meta WhatsApp Business API credentials (Optional)
# If blank, WhatsApp sharing will default to Manual Mode (wa.me link generation).
META_WA_PHONE_NUMBER_ID=
META_WA_ACCESS_TOKEN=
